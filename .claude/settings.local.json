{
  "permissions": {
    "allow": [
      "mcp__laravel-boost__last-error",
      "mcp__laravel-boost__browser-logs",
      "mcp__laravel-boost__read-log-entries",
      "mcp__laravel-boost__database-query",
      "Bash(npx tsc *)"
    ]
  },
  "enabledMcpjsonServers": [
    "laravel-boost"
  ],
  "mcpServers": {
    "laravel-boost": {
      "type": "stdio",
      "command": "php",
      "args": [
        "artisan",
        "boost:mcp"
      ]
    }
  }
}
